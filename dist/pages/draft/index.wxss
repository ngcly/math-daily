.draft-page{position:fixed;top:0;right:0;bottom:0;left:0;display:flex;flex-direction:column;background:var(--yellow)}.draft-page__canvas{flex:1;min-height:0}.float-card{position:absolute;bottom:180rpx;left:24rpx;right:24rpx;background:var(--white);border-radius:24rpx;box-shadow:0 8rpx 40rpx rgba(0,0,0,.14);border:1rpx solid var(--ink-5);overflow:hidden;transition:all .25s cubic-bezier(.25,.46,.45,.94)}.float-card--collapsed{bottom:180rpx}.float-card__header{display:flex;align-items:center;justify-content:space-between;padding:18rpx 24rpx}.float-card__pin-row{display:flex;align-items:center;gap:12rpx}.float-card__pin{font-size:24rpx;font-weight:700;color:var(--ink-3)}.float-card__done-tag{font-size:20rpx;font-weight:700;color:var(--green);background:var(--green-light);padding:4rpx 12rpx;border-radius:9999rpx;border:1rpx solid var(--green-border)}.float-card__toggle{font-size:22rpx;color:var(--ink-4);background:var(--paper);padding:4rpx 14rpx;border-radius:9999rpx}.float-card__body{padding:0 24rpx 20rpx}.float-card__text{font-size:26rpx;color:var(--ink-2);line-height:1.65;display:block}.fab-group{position:absolute;bottom:48rpx;left:24rpx;right:24rpx;display:flex;gap:16rpx;align-items:center}.fab{height:88rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;box-shadow:0 4rpx 24rpx rgba(0,0,0,.1);transition:opacity .15s}.fab:active{opacity:.8;transform:scale(.98)}.fab--ghost{width:88rpx;background:var(--fab-ghost-bg);border:2rpx solid var(--ink-5);flex-shrink:0}.fab--primary{flex:1;background:var(--ink)}.fab--done{flex:1;background:var(--green)}.fab__icon{font-size:32rpx;color:var(--ink-2)}.fab__label{font-size:28rpx;font-weight:700;color:var(--white);letter-spacing:2rpx}.answer-drawer{position:fixed;top:0;right:0;bottom:0;left:0;pointer-events:none;z-index:100}.answer-drawer--visible{pointer-events:auto}.answer-drawer__mask{position:absolute;top:0;right:0;bottom:0;left:0;background:rgba(0,0,0,0);transition:background .25s}.answer-drawer--visible .answer-drawer__mask{background:rgba(0,0,0,.4)}.answer-drawer__content{position:absolute;bottom:0;left:0;right:0;background:var(--white);border-radius:32rpx 32rpx 0 0;padding:24rpx 24rpx 48rpx;transform:translateY(100%);transition:transform .25s cubic-bezier(.25,.46,.45,.94)}.answer-drawer--visible .answer-drawer__content{transform:translateY(0)}.answer-drawer__handle{width:80rpx;height:8rpx;background:var(--ink-5);border-radius:9999rpx;margin:0 auto 24rpx}.answer-drawer__title{display:block;font-size:28rpx;font-weight:700;color:var(--ink);margin-bottom:24rpx;text-align:center}