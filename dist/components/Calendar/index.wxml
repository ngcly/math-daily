<view class="calendar"><view class="calendar__header"><view class="calendar__nav" bindtap="{{a}}"><text class="calendar__nav-icon">‹</text></view><view class="calendar__month-wrap"><text class="calendar__month">{{b}}</text><text class="calendar__rate">完成率 {{c}}%</text></view><view class="calendar__nav" bindtap="{{d}}"><text class="calendar__nav-icon">›</text></view></view><view class="calendar__weekdays"><text wx:for="{{e}}" wx:for-item="w" wx:key="b" class="calendar__wd">{{w.a}}</text></view><view class="calendar__grid"><view wx:for="{{f}}" wx:for-item="cell" wx:key="d" class="{{['calendar__cell', cell.e && 'calendar__cell--empty', cell.f && 'calendar__cell--today', cell.g && 'calendar__cell--done', cell.h && 'calendar__cell--correct', cell.i && 'calendar__cell--future', cell.j && 'calendar__cell--tappable']}}" bindtap="{{cell.k}}"><text class="calendar__day">{{cell.a}}</text><view wx:if="{{cell.b}}" class="{{['calendar__dot', cell.c]}}"/></view></view></view>