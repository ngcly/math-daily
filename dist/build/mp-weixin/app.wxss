.card{background:#fff;border-radius:24rpx;padding:28rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06)}.btn-primary{background:#1a1a1a;color:#fff;border-radius:16rpx;padding:24rpx 0;text-align:center;font-size:28rpx;font-weight:700;letter-spacing:4rpx;width:100%;border:none}.btn-primary:active{opacity:.85;transform:scale(.99)}.btn-primary--disabled{background:#aaa;pointer-events:none}.btn-ghost{border:2rpx solid #e4e4e4;color:#777;border-radius:16rpx;padding:20rpx 0;text-align:center;font-size:26rpx;font-weight:600;background:#fff}.tag{display:inline-flex;align-items:center;padding:4rpx 16rpx;border-radius:9999rpx;font-size:22rpx;font-weight:700}.tag--green{background:#e8f5e9;color:#2e7d32}.tag--amber{background:#fff3e0;color:#e65100}.tag--ink{background:#eeede8;color:#444}.divider{height:1rpx;background:#e4e4e4;margin:24rpx 0}
page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}