.draft-page{position:fixed;top:0;right:0;bottom:0;left:0;display:flex;flex-direction:column;background:#fffef5}.draft-page__canvas{flex:1;min-height:0}.float-card{position:absolute;bottom:180rpx;left:24rpx;right:24rpx;background:#fff;border-radius:24rpx;box-shadow:0 8rpx 40rpx rgba(0,0,0,.14);border:1rpx solid #e4e4e4;overflow:hidden;transition:all .25s cubic-bezier(.25,.46,.45,.94)}.float-card--collapsed{bottom:180rpx}.float-card__header{display:flex;align-items:center;justify-content:space-between;padding:18rpx 24rpx}.float-card__pin{font-size:24rpx;font-weight:700;color:#777}.float-card__toggle{font-size:22rpx;color:#aaa;background:#f5f4f0;padding:4rpx 14rpx;border-radius:9999rpx}.float-card__body{padding:0 24rpx 20rpx}.float-card__text{font-size:26rpx;color:#444;line-height:1.65;display:block}.fab-group{position:absolute;bottom:48rpx;left:24rpx;right:24rpx;display:flex;gap:16rpx;align-items:center}.fab{height:88rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;box-shadow:0 4rpx 24rpx rgba(0,0,0,.1);transition:opacity .15s}.fab:active{opacity:.8;transform:scale(.98)}.fab--ghost{width:88rpx;background:rgba(255,255,255,.9);border:2rpx solid #e4e4e4;flex-shrink:0}.fab--primary{flex:1;background:#1a1a1a}.fab__icon{font-size:32rpx;color:#444}.fab__label{font-size:28rpx;font-weight:700;color:#fff;letter-spacing:2rpx}.answer-drawer{position:fixed;top:0;right:0;bottom:0;left:0;pointer-events:none;z-index:100}.answer-drawer--visible{pointer-events:auto}.answer-drawer__mask{position:absolute;top:0;right:0;bottom:0;left:0;background:rgba(0,0,0,0);transition:background .25s}.answer-drawer--visible .answer-drawer__mask{background:rgba(0,0,0,.4)}.answer-drawer__content{position:absolute;bottom:0;left:0;right:0;background:#fff;border-radius:32rpx 32rpx 0 0;padding:24rpx 24rpx 48rpx;transform:translateY(100%);transition:transform .25s cubic-bezier(.25,.46,.45,.94)}.answer-drawer--visible .answer-drawer__content{transform:translateY(0)}.answer-drawer__handle{width:80rpx;height:8rpx;background:#e4e4e4;border-radius:9999rpx;margin:0 auto 24rpx}.answer-drawer__title{display:block;font-size:28rpx;font-weight:700;color:#1a1a1a;margin-bottom:24rpx;text-align:center}.answered-overlay{position:fixed;top:0;right:0;bottom:0;left:0;z-index:200;background:rgba(255,254,245,.92);display:flex;align-items:center;justify-content:center}.answered-card{background:#fff;border-radius:32rpx;padding:48rpx 40rpx;box-shadow:0 8rpx 40rpx rgba(0,0,0,.14);display:flex;flex-direction:column;align-items:center;gap:24rpx;width:560rpx;border:1rpx solid #e4e4e4}.answered-card__icon{font-size:80rpx}.answered-card__title{font-size:32rpx;font-weight:900;color:#1a1a1a}.answered-card__sub{font-size:24rpx;color:#aaa;text-align:center}.answered-card__btn{margin-top:16rpx;background:#2e7d32;border-radius:16rpx;width:100%;height:88rpx;display:flex;align-items:center;justify-content:center;transition:opacity .15s}.answered-card__btn:active{opacity:.85}.answered-card__btn-text{font-size:28rpx;font-weight:700;color:#fff;letter-spacing:2rpx}.answered-card__back{height:64rpx;display:flex;align-items:center;justify-content:center}.answered-card__back-text{font-size:26rpx;color:#aaa}