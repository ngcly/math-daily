.page{min-height:100vh;padding:0 24rpx 48rpx;background:var(--paper)}.header{display:flex;align-items:center;justify-content:space-between;padding:24rpx 0 16rpx}.header__title{font-size:44rpx;font-weight:900;color:var(--ink);letter-spacing:-1rpx}.streak-pill{display:flex;align-items:center;gap:6rpx;background:var(--amber-light);border:2rpx solid #ffcc80;border-radius:9999rpx;padding:8rpx 18rpx;transition:opacity .15s}.streak-pill:active{opacity:.7}.streak-pill__fire{font-size:28rpx}.streak-pill__num{font-size:22rpx;font-weight:700;color:var(--amber)}.date-label{display:block;font-size:22rpx;color:var(--ink-4);margin-bottom:24rpx;letter-spacing:1rpx}.loading-wrap,.empty-wrap{display:flex;flex-direction:column;align-items:center;padding:48rpx 0;gap:16rpx}.loading-wrap__text,.empty-wrap__text{font-size:28rpx;color:var(--ink-3)}.loading-wrap__emoji,.empty-wrap__emoji{font-size:80rpx}.loading-wrap__sub,.empty-wrap__sub{font-size:24rpx;color:var(--ink-4)}.q-card{background:var(--white);border-radius:24rpx;padding:28rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);margin-bottom:24rpx}.q-card__tag-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:16rpx}.q-card__right{display:flex;align-items:center;gap:16rpx}.q-card__dots{display:flex;gap:6rpx}.q-card__dot{width:12rpx;height:12rpx;border-radius:50%;background:var(--ink-5)}.q-card__dot--filled{background:var(--ink-3)}.q-card__body{font-size:30rpx;color:var(--ink);line-height:1.7;display:block}.q-card__image{width:100%;margin-top:24rpx;border-radius:16rpx}.draft-preview{min-height:200rpx;background:var(--yellow);border-radius:16rpx;border:3rpx dashed var(--yellow-border);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:18rpx;margin-bottom:24rpx;transition:opacity .15s}.draft-preview:active{opacity:.82}.draft-preview--done{background:var(--white);border-style:solid;border-color:var(--green-border)}.draft-preview__hint{font-size:28rpx;font-weight:700;color:var(--draft-hint)}.draft-preview__secondary{min-height:42rpx;padding:0 20rpx;display:flex;align-items:center;justify-content:center;color:var(--ink-3);font-size:24rpx;font-weight:600;transition:opacity .15s}.draft-preview__secondary:active{opacity:.65}.done-badge{font-size:20rpx;font-weight:700;color:var(--green);background:var(--green-light);padding:4rpx 14rpx;border-radius:9999rpx;border:1rpx solid var(--green-border)}.btn-primary--done{background:var(--green)}.train-eyebrow{display:flex;align-items:center;justify-content:space-between;margin-bottom:16rpx}.train-eyebrow__label{font-size:20rpx;font-weight:800;color:var(--ink-3);letter-spacing:2rpx;text-transform:uppercase}.train-eyebrow__meta{font-size:22rpx;font-weight:600;color:var(--ink-4)}.stats-hint{margin-top:24rpx;padding:20rpx 24rpx;background:var(--white);border-radius:16rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);display:flex;flex-direction:column;gap:16rpx}.stats-hint__row{display:flex;align-items:center;gap:16rpx}.stats-hint__key{font-size:22rpx;color:var(--ink-4);font-weight:600;min-width:96rpx;flex-shrink:0}.stats-hint__val{font-size:24rpx;font-weight:700;color:var(--amber)}.stats-hint__dims{display:flex;flex-wrap:wrap;gap:8rpx}.stats-hint__dim{font-size:20rpx;font-weight:600;color:var(--ink-3);background:var(--paper);border:1rpx solid var(--ink-5);border-radius:9999rpx;padding:4rpx 16rpx}