.page{min-height:100vh;padding:0 24rpx 48rpx;background:#f5f4f0}.header{display:flex;align-items:center;justify-content:space-between;padding:24rpx 0 16rpx}.header__title{font-size:44rpx;font-weight:900;color:#1a1a1a;letter-spacing:-1rpx}.streak-pill{display:flex;align-items:center;gap:6rpx;background:#fff3e0;border:2rpx solid #ffcc80;border-radius:9999rpx;padding:8rpx 18rpx}.streak-pill__fire{font-size:28rpx}.streak-pill__num{font-size:22rpx;font-weight:700;color:#e65100}.date-label{display:block;font-size:22rpx;color:#aaa;margin-bottom:24rpx;letter-spacing:1rpx}.loading-wrap,.empty-wrap{display:flex;flex-direction:column;align-items:center;padding:48rpx 0;gap:16rpx}.loading-wrap__text,.empty-wrap__text{font-size:28rpx;color:#777}.loading-wrap__emoji,.empty-wrap__emoji{font-size:80rpx}.loading-wrap__sub,.empty-wrap__sub{font-size:24rpx;color:#aaa}.q-card{background:#fff;border-radius:24rpx;padding:28rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);margin-bottom:24rpx}.q-card__tag-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:16rpx}.q-card__right{display:flex;align-items:center;gap:16rpx}.q-card__dots{display:flex;gap:6rpx}.q-card__dot{width:12rpx;height:12rpx;border-radius:50%;background:#e4e4e4}.q-card__dot--filled{background:#777}.q-card__body{font-size:30rpx;color:#1a1a1a;line-height:1.7;display:block}.q-card__image{width:100%;margin-top:24rpx;border-radius:16rpx}.tab-bar{display:flex;background:#e4e4e4;border-radius:16rpx;padding:6rpx;gap:4rpx;margin-bottom:24rpx}.tab-bar__item{flex:1;text-align:center;padding:12rpx 0;border-radius:8rpx;font-size:24rpx;color:#777;font-weight:600}.tab-bar__item--active{background:#fff;color:#1a1a1a;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);font-weight:800}.draft-preview{height:200rpx;background:#fffef5;border-radius:16rpx;border:3rpx dashed #e0d88a;display:flex;align-items:center;justify-content:center;margin-bottom:24rpx}.draft-preview__hint{font-size:26rpx;color:#b8ad60}.footer{margin-top:16rpx}.done-badge{font-size:20rpx;font-weight:700;color:#2e7d32;background:#e8f5e9;padding:4rpx 14rpx;border-radius:9999rpx;border:1rpx solid #a5d6a7}.btn-primary--done{background:#2e7d32}