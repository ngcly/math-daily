<view class="page"><view class="header"><text class="header__title">别让你的脑生锈</text><view wx:if="{{a}}" class="streak-pill" bindtap="{{c}}"><text class="streak-pill__fire">🔥</text><text class="streak-pill__num">{{b}} 天连续</text></view></view><text class="date-label">{{d}}</text><view wx:if="{{e}}" class="loading-wrap"><text class="loading-wrap__text">题目加载中...</text></view><view wx:elif="{{f}}" class="empty-wrap"><text class="empty-wrap__emoji">📭</text><text class="empty-wrap__text">今日暂无题目</text><text class="empty-wrap__sub">明天再来看看吧</text></view><block wx:else><view class="week-strip"><view wx:for="{{g}}" wx:for-item="day" wx:key="g" class="week-strip__day"><view class="{{['week-strip__dot', day.a && 'week-strip__dot--correct', day.b && 'week-strip__dot--wrong', day.c && 'week-strip__dot--today', day.d && 'week-strip__dot--future']}}"/><text class="{{['week-strip__label', day.f && 'week-strip__label--today']}}">{{day.e}}</text></view></view><view class="train-eyebrow"><text class="train-eyebrow__label">今日大脑训练</text><text class="train-eyebrow__meta">{{h}} · {{i}}</text></view><view class="q-card"><view class="q-card__tag-row"><view class="tag tag--green tag--category"><text class="tag__name">{{j}}</text><text class="tag__sub">{{k}}</text></view><view class="q-card__right"><view class="q-card__dots"><view wx:for="{{l}}" wx:for-item="i" wx:key="a" class="{{['q-card__dot', i.b && 'q-card__dot--filled']}}"/></view><text wx:if="{{m}}" class="done-badge">✓ 已完成</text></view></view><text class="q-card__body" user-select>{{n}}</text><image wx:if="{{o}}" class="q-card__image" src="{{p}}" mode="widthFix"/><view wx:if="{{q}}" class="social-bar"><text class="social-bar__text"> 已有 <text class="social-bar__num">{{r}}</text> 人挑战 · 正确率 <text class="social-bar__num">{{s}}%</text></text></view></view><view wx:if="{{t}}" class="daily-quote"><text class="daily-quote__text">{{v}}</text><text class="daily-quote__label">— 今日题眼</text></view><view class="{{['draft-preview', A && 'draft-preview--done']}}" bindtap="{{B}}"><text class="draft-preview__hint">{{w}}</text><view wx:if="{{x}}" class="draft-preview__secondary" catchtap="{{y}}"><text>回顾草稿</text></view><view wx:else class="draft-preview__secondary" catchtap="{{z}}"><text>已有思路？直接填写答案</text></view></view><view class="stats-hint"><view wx:if="{{C}}" class="stats-hint__row"><text class="stats-hint__key">连续思考</text><text class="stats-hint__val">{{D}} 天 🔥</text></view><view wx:if="{{E}}" class="stats-hint__row"><text class="stats-hint__key">最近训练</text><view class="stats-hint__dims"><text wx:for="{{F}}" wx:for-item="dim" wx:key="b" class="stats-hint__dim">{{dim.a}}</text></view></view></view></block></view>