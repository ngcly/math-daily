<view class="page"><view class="header"><text class="header__title">每日一题</text><view wx:if="{{a}}" class="streak-pill"><text class="streak-pill__fire">🔥</text><text class="streak-pill__num">{{b}} 天连续</text></view></view><text class="date-label">{{c}}</text><view wx:if="{{d}}" class="loading-wrap"><text class="loading-wrap__text">题目加载中...</text></view><view wx:elif="{{e}}" class="empty-wrap"><text class="empty-wrap__emoji">📭</text><text class="empty-wrap__text">今日暂无题目</text><text class="empty-wrap__sub">明天再来看看吧</text></view><block wx:else><view class="q-card"><view class="q-card__tag-row"><text class="tag tag--green">{{f}}</text><view class="q-card__right"><view class="q-card__dots"><view wx:for="{{g}}" wx:for-item="i" wx:key="a" class="{{['q-card__dot', i.b && 'q-card__dot--filled']}}"/></view><text wx:if="{{h}}" class="done-badge">✓ 已完成</text></view></view><text class="q-card__body" user-select>{{i}}</text><image wx:if="{{j}}" class="q-card__image" src="{{k}}" mode="widthFix"/></view><view class="tab-bar"><view class="{{['tab-bar__item', l && 'tab-bar__item--active']}}" bindtap="{{m}}">题目</view><view class="tab-bar__item" bindtap="{{n}}">✏️ 草稿纸</view><view class="{{['tab-bar__item', o && 'tab-bar__item--active']}}" bindtap="{{p}}">提交答案</view></view><view class="draft-preview" bindtap="{{q}}"><text class="draft-preview__hint">点击进入草稿纸演算 →</text></view><view class="footer"><view wx:if="{{r}}" class="btn-primary btn-primary--done" bindtap="{{s}}">查看今日解析 →</view><view wx:else class="btn-primary" bindtap="{{t}}"> 我想好了，提交答案 </view></view></block></view>