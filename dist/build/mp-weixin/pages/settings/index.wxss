.page{min-height:100vh;background:#f5f4f0}.content{padding:24rpx 24rpx 48rpx}.page-title{display:block;font-size:48rpx;font-weight:900;color:#1a1a1a;letter-spacing:-1rpx;margin-bottom:24rpx}.section-card{background:#fff;border-radius:24rpx;padding:24rpx;margin-bottom:24rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06)}.section-card__title{display:block;font-size:26rpx;font-weight:800;color:#1a1a1a;margin-bottom:24rpx}.section-card__desc{display:block;font-size:22rpx;color:#aaa;margin-bottom:16rpx;margin-top:-16rpx}.section-card__row{display:flex;align-items:center;justify-content:space-between;padding:16rpx 0;border-bottom:1rpx solid #e4e4e4}.section-card__row:last-child{border-bottom:none}.section-card__row--btn{border-bottom:none;padding-top:16rpx}.section-card__label{font-size:28rpx;color:#444}.section-card__value{font-size:26rpx;color:#777;font-weight:600;max-width:55%;text-align:right}.section-card--about .section-card__title{color:#777}.about-quote{font-size:28rpx;font-weight:700;color:#444;letter-spacing:1rpx}.section-card__row--concept{align-items:center}.picker-value{display:flex;align-items:center;gap:8rpx;font-size:28rpx;color:#444;font-weight:700}.picker-arrow{font-size:32rpx;color:#aaa}.cat-grid{display:flex;flex-wrap:wrap;gap:16rpx}.cat-chip{padding:10rpx 22rpx;border-radius:9999rpx;background:#f5f4f0;border:2rpx solid #e4e4e4;font-size:24rpx;color:#777;font-weight:600;transition:all .15s}.cat-chip--selected{background:#1a1a1a;border-color:#1a1a1a;color:#fff}.cat-chip:active{opacity:.7}.diff-row{display:flex;gap:16rpx}.diff-chip{flex:1;text-align:center;padding:12rpx 0;border-radius:16rpx;background:#f5f4f0;border:2rpx solid #e4e4e4;font-size:26rpx;color:#777;font-weight:600;transition:all .15s}.diff-chip--selected{background:#1a1a1a;border-color:#1a1a1a;color:#fff}.diff-chip:active{opacity:.7}.outline-btn{width:100%;height:80rpx;border:2rpx solid #e4e4e4;border-radius:16rpx;display:flex;align-items:center;justify-content:center;font-size:26rpx;color:#444;font-weight:600;transition:all .15s}.outline-btn:active{background:#f5f4f0}.outline-btn--disabled{opacity:.4;pointer-events:none}