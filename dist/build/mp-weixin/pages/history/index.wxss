.page{min-height:100vh;background:var(--paper)}.content{padding:24rpx 24rpx 48rpx}.page-title{display:block;font-size:48rpx;font-weight:900;color:var(--ink);letter-spacing:-1rpx;margin-bottom:24rpx}.stat-row{display:flex;gap:16rpx;margin-bottom:24rpx}.stat-card{flex:1;background:var(--white);border-radius:16rpx;padding:24rpx 16rpx;text-align:center;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);display:flex;flex-direction:column;gap:4rpx}.stat-card__num{font-size:36rpx;font-weight:900;color:var(--ink);letter-spacing:-1rpx}.stat-card__label{font-size:20rpx;color:var(--ink-4);font-weight:600}.calendar-wrap{margin-bottom:24rpx}.history-list__title{display:block;font-size:26rpx;font-weight:800;color:var(--ink-3);letter-spacing:1px;margin-bottom:16rpx}.history-list__loading,.history-list__empty{display:flex;flex-direction:column;align-items:center;padding:48rpx 0;gap:16rpx;color:var(--ink-4);font-size:28rpx}.history-list__empty-emoji{font-size:64rpx}.history-list__empty-text{font-size:26rpx;color:var(--ink-4)}.history-item{display:flex;align-items:center;gap:24rpx;background:var(--white);border-radius:16rpx;padding:20rpx 24rpx;margin-bottom:16rpx;box-shadow:0 1rpx 6rpx rgba(0,0,0,.05);transition:opacity .15s}.history-item:active{opacity:.75}.history-item__date{text-align:center;min-width:56rpx}.history-item__month{font-size:22rpx;font-weight:700;color:var(--ink-3)}.history-item__info{flex:1;display:flex;flex-direction:column;gap:6rpx}.history-item__title{font-size:28rpx;font-weight:600;color:var(--ink)}.history-item__meta{display:flex;align-items:center;gap:16rpx}.history-item__time{font-size:22rpx;color:var(--ink-4)}.history-item__result{font-size:32rpx;flex-shrink:0}