<scroll-view class="page" scroll-y show-scrollbar="{{false}}"><view class="content"><text class="page-title">我的记录</text><view class="stat-row"><view class="stat-card"><text class="stat-card__num">🔥 {{a}}</text><text class="stat-card__label">连续天数</text></view><view class="stat-card"><text class="stat-card__num">{{b}}</text><text class="stat-card__label">本月完成</text></view><view class="stat-card"><text class="stat-card__num">{{c}}%</text><text class="stat-card__label">正确率</text></view></view><calendar wx:if="{{g}}" bindprevMonth="{{d}}" bindnextMonth="{{e}}" binddayClick="{{f}}" class="calendar-wrap" u-i="5cf8c09e-0" bind:__l="__l" u-p="{{g}}"/><view class="history-list"><text class="history-list__title">本月记录</text><view wx:if="{{h}}" class="history-list__loading"><text>加载中...</text></view><view wx:elif="{{i}}" class="history-list__empty"><text class="history-list__empty-emoji">📭</text><text class="history-list__empty-text">本月还没有记录</text></view><view wx:for="{{j}}" wx:for-item="record" wx:key="g" class="history-item" bindtap="{{record.h}}"><view class="history-item__date"><text class="history-item__month">{{record.a}}/{{record.b}}</text></view><view class="history-item__info"><text class="history-item__title">{{record.c}}</text><view class="history-item__meta"><text class="tag tag--ink">{{record.d}}</text><text class="history-item__time">{{record.e}}</text></view></view><view class="history-item__right"><text class="history-item__result">{{record.f}}</text><text class="history-item__arrow">›</text></view></view></view></view></scroll-view>