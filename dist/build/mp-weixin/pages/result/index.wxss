.page{min-height:100vh;background:var(--white)}.content{padding:24rpx 24rpx 48rpx}.milestone{display:flex;align-items:center;gap:16rpx;background:var(--amber-light);border-radius:16rpx;padding:16rpx 24rpx;margin-bottom:24rpx;border:1rpx solid var(--milestone-border)}.milestone__emoji{font-size:36rpx}.milestone__text{font-size:26rpx;font-weight:700;color:var(--amber)}.section{margin-bottom:24rpx}.section__title{display:block;font-size:26rpx;font-weight:800;color:var(--ink);margin-bottom:16rpx;letter-spacing:.5px}.analysis-card{background:var(--paper);border-radius:16rpx;padding:24rpx;border-left:6rpx solid var(--ink)}.analysis-card__text{font-size:28rpx;color:var(--ink-2);line-height:1.8;display:block}.aha-box{background:linear-gradient(135deg,var(--aha-from),var(--aha-to));border-radius:16rpx;padding:24rpx;margin-bottom:24rpx;border:1rpx solid var(--aha-border)}.aha-box__label{display:block;font-size:22rpx;font-weight:800;color:var(--aha-label);letter-spacing:1px;margin-bottom:8rpx}.aha-box__text{display:block;font-size:30rpx;font-weight:700;color:var(--ink);line-height:1.6}.alt-solution{border:2rpx dashed var(--ink-5);border-radius:16rpx;margin-bottom:24rpx;overflow:hidden}.alt-solution__header{display:flex;align-items:center;justify-content:space-between;padding:20rpx 24rpx}.alt-solution__label{font-size:26rpx;color:var(--ink-3);font-weight:600}.alt-solution__arrow{font-size:24rpx;color:var(--ink-4)}.alt-solution__body{padding:0 24rpx 20rpx;border-top:1rpx solid var(--ink-5)}.alt-solution__text{display:block;font-size:26rpx;color:var(--ink-2);line-height:1.75;padding-top:16rpx}.copy-section{margin-bottom:24rpx}.copy-section__label{display:block;font-size:22rpx;font-weight:800;color:var(--ink-3);letter-spacing:1px;margin-bottom:16rpx;text-transform:uppercase}.copy-card{background:var(--paper);border-radius:16rpx;padding:24rpx;margin-bottom:16rpx;display:flex;align-items:flex-start;gap:16rpx}.copy-card__text{flex:1;font-size:26rpx;color:var(--ink-2);line-height:1.75;white-space:pre-line}.copy-card__btn{flex-shrink:0;height:56rpx;padding:0 24rpx;background:var(--ink);border-radius:8rpx;display:flex;align-items:center;justify-content:center;font-size:24rpx;font-weight:700;color:var(--white);letter-spacing:1px}.copy-card__btn:active{opacity:.75}.actions{display:flex;flex-direction:column;gap:16rpx;margin-top:24rpx}.actions__share{width:100%;height:96rpx;background:#07c160;border-radius:16rpx;display:flex;align-items:center;justify-content:center;transition:opacity .15s;border:none;padding:0}.actions__share:active{opacity:.85}.actions__share-text{font-size:30rpx;font-weight:700;color:var(--white);letter-spacing:1px}.actions__timeline{width:100%;height:88rpx;background:var(--white);border:2rpx solid var(--ink-5);border-radius:16rpx;display:flex;align-items:center;justify-content:center;transition:opacity .15s;padding:0}.actions__timeline:active{background:var(--paper)}.actions__timeline-text{font-size:28rpx;font-weight:600;color:var(--ink-2)}.actions__subscribe{height:88rpx;background:var(--white);border:2rpx solid var(--ink-5);border-radius:16rpx;display:flex;align-items:center;justify-content:center}.actions__subscribe:active{background:var(--paper)}.actions__subscribe-text{font-size:28rpx;color:var(--ink-2);font-weight:600}.actions__home{height:80rpx;display:flex;align-items:center;justify-content:center}.actions__home-text{font-size:26rpx;color:var(--ink-4)}.empty{display:flex;align-items:center;justify-content:center;height:50vh;font-size:28rpx;color:var(--ink-4)}