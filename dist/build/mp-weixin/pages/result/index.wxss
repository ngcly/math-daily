.page{min-height:100vh;background:#fff}.content{padding:24rpx 24rpx 48rpx}.milestone{display:flex;align-items:center;gap:16rpx;background:#fff3e0;border-radius:16rpx;padding:16rpx 24rpx;margin-bottom:24rpx;border:1rpx solid #ffcc80}.milestone__emoji{font-size:36rpx}.milestone__text{font-size:26rpx;font-weight:700;color:#e65100}.section{margin-bottom:24rpx}.section__title{display:block;font-size:26rpx;font-weight:800;color:#1a1a1a;margin-bottom:16rpx;letter-spacing:.5px}.analysis-card{background:#f5f4f0;border-radius:16rpx;padding:24rpx;border-left:6rpx solid #1a1a1a}.analysis-card__text{font-size:28rpx;color:#444;line-height:1.8;display:block}.aha-box{background:linear-gradient(135deg,#fffde7,#fff9c4);border-radius:16rpx;padding:24rpx;margin-bottom:24rpx;border:1rpx solid #f9e57a}.aha-box__label{display:block;font-size:22rpx;font-weight:800;color:#b8860b;letter-spacing:1px;margin-bottom:8rpx}.aha-box__text{display:block;font-size:30rpx;font-weight:700;color:#1a1a1a;line-height:1.6}.alt-solution{border:2rpx dashed #e4e4e4;border-radius:16rpx;margin-bottom:24rpx;overflow:hidden}.alt-solution__header{display:flex;align-items:center;justify-content:space-between;padding:20rpx 24rpx}.alt-solution__label{font-size:26rpx;color:#777;font-weight:600}.alt-solution__arrow{font-size:24rpx;color:#aaa}.alt-solution__body{padding:0 24rpx 20rpx;border-top:1rpx solid #e4e4e4}.alt-solution__text{display:block;font-size:26rpx;color:#444;line-height:1.75;padding-top:16rpx}.actions{display:flex;flex-direction:column;gap:16rpx;margin-top:24rpx}.actions__share{height:96rpx;background:#07c160;border-radius:16rpx;display:flex;align-items:center;justify-content:center;transition:opacity .15s}.actions__share--loading{opacity:.7}.actions__share:active{opacity:.85}.actions__share-text{font-size:30rpx;font-weight:700;color:#fff;letter-spacing:1px}.actions__subscribe{height:88rpx;background:#fff;border:2rpx solid #e4e4e4;border-radius:16rpx;display:flex;align-items:center;justify-content:center}.actions__subscribe:active{background:#f5f4f0}.actions__subscribe-text{font-size:28rpx;color:#444;font-weight:600}.actions__home{height:80rpx;display:flex;align-items:center;justify-content:center}.actions__home-text{font-size:26rpx;color:#aaa}.empty{display:flex;align-items:center;justify-content:center;height:50vh;font-size:28rpx;color:#aaa}