.page{min-height:100vh;background:var(--white)}.content{padding:24rpx 24rpx 48rpx}.loading{display:flex;align-items:center;justify-content:center;height:50vh}.loading__text{font-size:28rpx;color:var(--ink-4)}.q-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16rpx}.q-header__tags{display:flex;align-items:center;gap:16rpx}.q-header__sub{font-size:20rpx;color:var(--ink-4);font-weight:500}.q-header__dots{display:flex;gap:6rpx}.q-header__dot{width:12rpx;height:12rpx;border-radius:50%;background:var(--ink-5)}.q-header__dot--filled{background:var(--ink-3)}.q-body{background:var(--paper);border-radius:24rpx;padding:24rpx 28rpx;margin-bottom:24rpx;border-left:6rpx solid var(--ink-3)}.q-body__title{display:block;font-size:22rpx;font-weight:700;color:var(--ink-4);letter-spacing:1rpx;margin-bottom:10rpx}.q-body__text{display:block;font-size:30rpx;color:var(--ink);line-height:1.7}.q-body__image{width:100%;margin-top:24rpx;border-radius:16rpx}.my-answer{background:var(--paper);border-radius:16rpx;padding:20rpx 24rpx;margin-bottom:24rpx}.my-answer__label{display:block;font-size:20rpx;font-weight:700;color:var(--ink-4);letter-spacing:2rpx;margin-bottom:10rpx}.my-answer__row{display:flex;align-items:center;gap:16rpx;margin-bottom:6rpx}.my-answer__value{font-size:30rpx;font-weight:700;color:var(--ink)}.my-answer__badge{font-size:20rpx;font-weight:700;padding:4rpx 14rpx;border-radius:9999rpx}.my-answer__badge--correct{color:var(--green);background:var(--green-light);border:1rpx solid var(--green-border)}.my-answer__badge--wrong{color:var(--red);background:var(--red-light);border:1rpx solid var(--red)}.my-answer__time{font-size:22rpx;color:var(--ink-4)}.section{margin-bottom:24rpx}.section__title{display:block;font-size:26rpx;font-weight:800;color:var(--ink);margin-bottom:16rpx}.analysis-card{background:var(--paper);border-radius:16rpx;padding:24rpx;border-left:6rpx solid var(--ink)}.analysis-card__text{font-size:28rpx;color:var(--ink-2);line-height:1.8;display:block}.aha-box{background:linear-gradient(135deg,var(--aha-from),var(--aha-to));border-radius:16rpx;padding:24rpx;margin-bottom:24rpx;border:1rpx solid var(--aha-border)}.aha-box__label{display:block;font-size:22rpx;font-weight:800;color:var(--aha-label);letter-spacing:1px;margin-bottom:8rpx}.aha-box__text{display:block;font-size:30rpx;font-weight:700;color:var(--ink);line-height:1.6}.trap-box{background:var(--red-light);border-radius:16rpx;padding:24rpx;margin-bottom:24rpx;border-left:6rpx solid var(--red)}.trap-box__label{display:block;font-size:22rpx;font-weight:800;color:var(--red);letter-spacing:1px;margin-bottom:8rpx}.trap-box__text{display:block;font-size:28rpx;color:var(--ink-2);line-height:1.8}.alt-solution{border:2rpx dashed var(--ink-5);border-radius:16rpx;margin-bottom:24rpx;overflow:hidden}.alt-solution__header{display:flex;align-items:center;justify-content:space-between;padding:20rpx 24rpx}.alt-solution__label{font-size:26rpx;color:var(--ink-3);font-weight:600}.alt-solution__arrow{font-size:24rpx;color:var(--ink-4)}.alt-solution__body{padding:0 24rpx 20rpx;border-top:1rpx solid var(--ink-5)}.alt-solution__text{display:block;font-size:26rpx;color:var(--ink-2);line-height:1.75;padding-top:16rpx}