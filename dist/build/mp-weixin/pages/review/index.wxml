<scroll-view class="page" scroll-y show-scrollbar="{{false}}"><view wx:if="{{a}}" class="loading"><text class="loading__text">加载中...</text></view><view wx:elif="{{b}}" class="content"><view class="q-header"><view class="q-header__tags"><view class="tag tag--green">{{c}}</view><text class="q-header__sub">{{d}}</text></view><view class="q-header__dots"><view wx:for="{{e}}" wx:for-item="i" wx:key="a" class="{{['q-header__dot', i.b && 'q-header__dot--filled']}}"/></view></view><view class="q-body"><text class="q-body__title">{{f}}</text><text class="q-body__text" user-select>{{g}}</text><image wx:if="{{h}}" class="q-body__image" src="{{i}}" mode="widthFix"/></view><view class="my-answer"><text class="my-answer__label">我的作答</text><view class="my-answer__row"><text class="my-answer__value">{{j}}</text><text class="{{['my-answer__badge', l]}}">{{k}}</text></view><text class="my-answer__time">用时 {{m}}</text></view><result-banner wx:if="{{n}}" u-i="1f91299e-0" bind:__l="__l" u-p="{{n}}"/><view class="section"><text class="section__title">💡 解题思路</text><view class="analysis-card"><text class="analysis-card__text">{{o}}</text></view></view><view wx:if="{{p}}" class="aha-box"><text class="aha-box__label">✨ 核心洞察</text><text class="aha-box__text">{{q}}</text></view><view wx:if="{{r}}" class="trap-box"><text class="trap-box__label">⚠️ 大多数人栽在这里</text><text class="trap-box__text">{{s}}</text></view><view wx:if="{{t}}" class="alt-solution" bindtap="{{y}}"><view class="alt-solution__header"><text class="alt-solution__label">💭 还有另一种思路</text><text class="alt-solution__arrow">{{v}}</text></view><view wx:if="{{w}}" class="alt-solution__body"><text class="alt-solution__text">{{x}}</text></view></view></view></scroll-view>