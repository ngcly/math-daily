.result-banner{margin-bottom:24rpx}.banner{display:flex;align-items:center;gap:24rpx;border-radius:24rpx;padding:24rpx 28rpx;margin-bottom:16rpx;border:1rpx solid transparent}.banner--correct{background:linear-gradient(135deg,var(--banner-correct-from),var(--banner-correct-to));border-color:var(--green-border)}.banner--wrong{background:linear-gradient(135deg,var(--banner-wrong-from),var(--banner-wrong-to));border-color:var(--banner-wrong-border)}.banner__emoji{font-size:56rpx;flex-shrink:0}.banner__info{display:flex;flex-direction:column;gap:4rpx}.banner__main{font-size:32rpx;font-weight:800;color:var(--ink)}.banner__sub{font-size:22rpx;color:var(--ink-3)}.stats{display:flex;background:var(--white);border-radius:16rpx;border:1rpx solid var(--ink-5);overflow:hidden;margin-bottom:16rpx}.stats__item{flex:1;display:flex;flex-direction:column;align-items:center;padding:20rpx 0;gap:4rpx}.stats__divider{width:1rpx;background:var(--ink-5);margin:16rpx 0}.stats__num{font-size:36rpx;font-weight:900;color:var(--ink);letter-spacing:-1rpx}.stats__num--red{color:var(--red)}.stats__num--amber{color:var(--amber)}.stats__label{font-size:20rpx;color:var(--ink-4);font-weight:500}.correct-ans{display:flex;align-items:center;gap:16rpx;background:var(--green-light);border-radius:16rpx;padding:18rpx 24rpx;border:1rpx solid var(--green-border)}.correct-ans__label{font-size:24rpx;color:var(--green);font-weight:700}.correct-ans__value{font-size:28rpx;font-weight:900;color:var(--green)}