.result-banner{margin-bottom:24rpx}.banner{display:flex;align-items:center;gap:24rpx;border-radius:24rpx;padding:24rpx 28rpx;margin-bottom:16rpx;border:1rpx solid transparent}.banner--correct{background:linear-gradient(135deg,#e8f5e9,#f9fbe7);border-color:#a5d6a7}.banner--wrong{background:linear-gradient(135deg,#ffebee,#fff3e0);border-color:#ef9a9a}.banner__emoji{font-size:56rpx;flex-shrink:0}.banner__info{display:flex;flex-direction:column;gap:4rpx}.banner__main{font-size:32rpx;font-weight:800;color:#1a1a1a}.banner__sub{font-size:22rpx;color:#777}.stats{display:flex;background:#fff;border-radius:16rpx;border:1rpx solid #e4e4e4;overflow:hidden;margin-bottom:16rpx}.stats__item{flex:1;display:flex;flex-direction:column;align-items:center;padding:20rpx 0;gap:4rpx}.stats__divider{width:1rpx;background:#e4e4e4;margin:16rpx 0}.stats__num{font-size:36rpx;font-weight:900;color:#1a1a1a;letter-spacing:-1rpx}.stats__num--red{color:#c62828}.stats__num--amber{color:#e65100}.stats__label{font-size:20rpx;color:#aaa;font-weight:500}.correct-ans{display:flex;align-items:center;gap:16rpx;background:#e8f5e9;border-radius:16rpx;padding:18rpx 24rpx;border:1rpx solid #a5d6a7}.correct-ans__label{font-size:24rpx;color:#2e7d32;font-weight:700}.correct-ans__value{font-size:28rpx;font-weight:900;color:#2e7d32}