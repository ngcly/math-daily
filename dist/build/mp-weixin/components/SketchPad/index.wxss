.sketchpad{display:flex;flex-direction:column;height:100%;background:#fffef5}.toolbar{display:flex;align-items:center;gap:8rpx;padding:12rpx 16rpx;background:#fff;border-bottom:1rpx solid #e4e4e4;flex-shrink:0}.toolbar__btn{width:56rpx;height:56rpx;border-radius:8rpx;display:flex;align-items:center;justify-content:center;background:#f5f4f0;transition:background .15s}.toolbar__btn--active{background:#1a1a1a}.toolbar__btn--active .toolbar__icon{filter:brightness(10)}.toolbar__btn--disabled{opacity:.3;pointer-events:none}.toolbar__btn--danger:active{background:#ffebee}.toolbar__btn:active{opacity:.7}.toolbar__icon{font-size:32rpx;line-height:1}.toolbar__sep{width:1rpx;height:36rpx;background:#e4e4e4;margin:0 4rpx;flex-shrink:0}.toolbar__width{width:48rpx;height:48rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;border:2rpx solid transparent;transition:border-color .15s}.toolbar__width--active{border-color:#1a1a1a}.toolbar__dot{background:#1a1a1a;border-radius:50%;flex-shrink:0}.toolbar__color{width:40rpx;height:40rpx;border-radius:50%;border:3rpx solid transparent;transition:border-color .15s}.toolbar__color--active{border-color:#777;outline:3rpx solid #ffffff}.canvas{flex:1;width:100%;touch-action:none}