.answer-input__notice{display:block;text-align:center;font-size:22rpx;color:#aaa;margin-top:16rpx}.answer-input__field{flex:1;height:88rpx;background:#f5f4f0;border-radius:16rpx;padding:0 24rpx;font-size:32rpx;font-weight:600;color:#1a1a1a;border:2rpx solid #e4e4e4;transition:border-color .15s}.answer-input__field:focus{border-color:#777}.choice-list{display:flex;flex-direction:column;gap:16rpx;margin-bottom:24rpx}.choice-item{display:flex;align-items:center;gap:24rpx;padding:24rpx;background:#f5f4f0;border-radius:16rpx;border:2rpx solid #e4e4e4;transition:all .15s}.choice-item--selected{background:#e8f5e9;border-color:#a5d6a7}.choice-item--disabled{opacity:.7}.choice-item:active{opacity:.8}.choice-item__key{width:56rpx;height:56rpx;border-radius:50%;background:#fff;border:2rpx solid #e4e4e4;display:flex;align-items:center;justify-content:center;font-size:26rpx;font-weight:800;color:#777;flex-shrink:0;transition:all .15s}.choice-item__key--selected{background:#2e7d32;border-color:#2e7d32;color:#fff}.choice-item__text{font-size:28rpx;color:#1a1a1a;line-height:1.5;flex:1}.fill-wrap{margin-bottom:24rpx}.fill-wrap__label{display:block;font-size:26rpx;color:#777;margin-bottom:16rpx}.fill-wrap__row{display:flex;align-items:center;gap:16rpx}.fill-wrap__unit{font-size:28rpx;color:#444;font-weight:600;flex-shrink:0}.fill-wrap__hint{display:block;font-size:22rpx;color:#aaa;margin-top:10rpx}.submit-btn{height:96rpx;background:#1a1a1a;border-radius:16rpx;display:flex;align-items:center;justify-content:center;margin-bottom:16rpx;transition:opacity .15s}.submit-btn__label{font-size:30rpx;font-weight:700;color:#fff;letter-spacing:2rpx}.submit-btn--disabled{background:#aaa;pointer-events:none}.submit-btn--loading{opacity:.7}.submit-btn:active{opacity:.85}