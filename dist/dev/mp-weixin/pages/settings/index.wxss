.page {
  min-height: 100vh;
  background: var(--paper);
}
.content {
  padding: 24rpx 24rpx 48rpx;
}
.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: -1rpx;
  margin-bottom: 24rpx;
}
.section-card {
  background: var(--white);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.section-card__title {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
  color: var(--ink);
  margin-bottom: 24rpx;
}
.section-card__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--ink-5);
}
.section-card__row:last-child {
  border-bottom: none;
}
.section-card__row--btn {
  border-bottom: none;
  padding-top: 16rpx;
}
.section-card__label {
  font-size: 28rpx;
  color: var(--ink-2);
  flex-shrink: 0;
}
.section-card__value {
  font-size: 26rpx;
  color: var(--ink-3);
  font-weight: 600;
  max-width: 55%;
  text-align: right;
}
.section-card__value--active {
  color: var(--green);
}
.section-card--about .section-card__title {
  color: var(--ink-3);
}
.profile-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 6rpx 0;
}
.profile-avatar-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  padding: 0;
  border: none;
  background: none;
  flex-shrink: 0;
  overflow: hidden;
}
.profile-avatar-btn::after {
  display: none;
}
.profile-avatar-btn:active {
  opacity: 0.75;
}
.profile-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
  background: var(--paper);
  border: 2rpx solid var(--ink-5);
}
.profile-avatar--empty {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.profile-info__hint {
  font-size: 22rpx;
  color: var(--ink-4);
  line-height: 1;
}
.profile-info__input {
  width: 100%;
  min-height: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink);
}
.profile-info__placeholder {
  color: var(--ink-4);
  font-weight: 400;
}
.profile-arrow {
  font-size: 40rpx;
  color: var(--ink-5);
  flex-shrink: 0;
  line-height: 1;
  margin-top: 12rpx;
}
.about-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 0 16rpx;
}
.about-footer__quote {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--ink-3);
  line-height: 1.75;
  text-align: center;
  letter-spacing: 0.5rpx;
}
.about-footer__copy {
  font-size: 22rpx;
  color: var(--ink-4);
}
.picker-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: var(--ink-2);
  font-weight: 700;
}
.picker-arrow {
  font-size: 32rpx;
  color: var(--ink-4);
}
.outline-btn {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid var(--ink-5);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--ink-2);
  font-weight: 600;
  transition: all 150ms;
}
.outline-btn:active {
  background: var(--paper);
}
.outline-btn--disabled {
  opacity: 0.4;
  pointer-events: none;
}