.page {
  min-height: 100vh;
  background: var(--paper);
}
.content {
  padding: 24rpx 24rpx 48rpx;
}
.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: -1rpx;
  margin-bottom: 24rpx;
}
.section-card {
  background: var(--white);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.section-card__title {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
  color: var(--ink);
  margin-bottom: 24rpx;
}
.section-card__desc {
  display: block;
  font-size: 22rpx;
  color: var(--ink-4);
  margin-bottom: 16rpx;
  margin-top: -16rpx;
}
.section-card__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--ink-5);
}
.section-card__row:last-child {
  border-bottom: none;
}
.section-card__row--btn {
  border-bottom: none;
  padding-top: 16rpx;
}
.section-card__label {
  font-size: 28rpx;
  color: var(--ink-2);
}
.section-card__value {
  font-size: 26rpx;
  color: var(--ink-3);
  font-weight: 600;
  max-width: 55%;
  text-align: right;
}
.section-card--about .section-card__title {
  color: var(--ink-3);
}
.about-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 0 16rpx;
}
.about-footer__quote {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--ink-3);
  line-height: 1.75;
  text-align: center;
  letter-spacing: 0.5rpx;
}
.about-footer__copy {
  font-size: 22rpx;
  color: var(--ink-4);
}
.picker-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: var(--ink-2);
  font-weight: 700;
}
.picker-arrow {
  font-size: 32rpx;
  color: var(--ink-4);
}
.cat-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.cat-chip {
  padding: 10rpx 22rpx;
  border-radius: 9999rpx;
  background: var(--paper);
  border: 2rpx solid var(--ink-5);
  font-size: 24rpx;
  color: var(--ink-3);
  font-weight: 600;
  transition: all 150ms;
}
.cat-chip--selected {
  background: var(--ink);
  border-color: var(--ink);
  color: var(--white);
}
.cat-chip:active {
  opacity: 0.7;
}
.diff-row {
  display: flex;
  gap: 16rpx;
}
.diff-chip {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 16rpx;
  background: var(--paper);
  border: 2rpx solid var(--ink-5);
  font-size: 26rpx;
  color: var(--ink-3);
  font-weight: 600;
  transition: all 150ms;
}
.diff-chip--selected {
  background: var(--ink);
  border-color: var(--ink);
  color: var(--white);
}
.diff-chip:active {
  opacity: 0.7;
}
.outline-btn {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid var(--ink-5);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--ink-2);
  font-weight: 600;
  transition: all 150ms;
}
.outline-btn:active {
  background: var(--paper);
}
.outline-btn--disabled {
  opacity: 0.4;
  pointer-events: none;
}