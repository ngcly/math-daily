<scroll-view class="{{['page', v]}}" scroll-y show-scrollbar="{{false}}"><view wx:if="{{a}}" class="content"><view wx:if="{{b}}" class="milestone"><text class="milestone__emoji">🏆</text><text class="milestone__text">连续 {{c}} 天！你真厉害</text></view><result-banner wx:if="{{d}}" u-i="c44a2382-0" bind:__l="__l" u-p="{{d}}"/><view class="section"><text class="section__title">💡 解题思路</text><view class="analysis-card"><text class="analysis-card__text">{{e}}</text></view></view><view wx:if="{{f}}" class="aha-box"><text class="aha-box__label">✨ 核心洞察</text><text class="aha-box__text">{{g}}</text></view><view wx:if="{{h}}" class="alt-solution" bindtap="{{l}}"><view class="alt-solution__header"><text class="alt-solution__label">💭 还有另一种思路</text><text class="alt-solution__arrow">{{i}}</text></view><view wx:if="{{j}}" class="alt-solution__body"><text class="alt-solution__text">{{k}}</text></view></view><view class="copy-section"><text class="copy-section__label">📋 朋友圈文案</text><view class="copy-card"><text class="copy-card__text">{{m}}</text><view class="copy-card__btn" bindtap="{{n}}">复制</view></view><view wx:if="{{o}}" class="copy-card"><text class="copy-card__text">{{p}}</text><view class="copy-card__btn" bindtap="{{q}}">复制</view></view></view><view class="actions"><button class="actions__share" open-type="share"><text class="actions__share-text">💬 分享给朋友</text></button><view class="actions__timeline" bindtap="{{r}}"><text class="actions__timeline-text">🌐 分享到朋友圈</text></view><view class="actions__subscribe" bindtap="{{s}}"><text class="actions__subscribe-text">🔔 订阅明日提醒</text></view><view class="actions__home" bindtap="{{t}}"><text class="actions__home-text">回首页</text></view></view></view><view wx:else class="empty"><text>加载中...</text></view></scroll-view>