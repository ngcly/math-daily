.page {
  min-height: 100vh;
  background: var(--paper);
}
.content {
  padding: 24rpx 24rpx 48rpx;
}
.success {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  gap: 24rpx;
}
.success__emoji {
  font-size: 96rpx;
}
.success__title {
  font-size: 40rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: -1rpx;
}
.success__sub {
  font-size: 26rpx;
  color: var(--ink-3);
}
.success__btn {
  margin-top: 16rpx;
  height: 88rpx;
  padding: 0 64rpx;
  background: var(--ink);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--white);
  letter-spacing: 2rpx;
}
.success__btn:active {
  opacity: 0.85;
}
.form-label {
  display: block;
  font-size: 22rpx;
  font-weight: 800;
  color: var(--ink-3);
  letter-spacing: 1px;
  margin-bottom: 16rpx;
  text-transform: uppercase;
}
.category-list {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}
.category-item {
  flex: 1;
  min-width: 140rpx;
  height: 96rpx;
  background: var(--white);
  border: 2rpx solid var(--ink-5);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  transition: all 150ms;
}
.category-item:active {
  opacity: 0.75;
}
.category-item--active {
  background: var(--green-light);
  border-color: var(--green-border);
}
.category-item__emoji {
  font-size: 32rpx;
  line-height: 1;
}
.category-item__label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--ink-2);
}
.category-item--active .category-item__label {
  color: var(--green);
}
.textarea-wrap {
  background: var(--white);
  border-radius: 16rpx;
  border: 2rpx solid var(--ink-5);
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  position: relative;
}
.feedback-textarea {
  width: 100%;
  min-height: 240rpx;
  font-size: 28rpx;
  color: var(--ink);
  line-height: 1.75;
}
.feedback-textarea__placeholder {
  color: var(--ink-4);
}
.char-count {
  display: block;
  text-align: right;
  font-size: 20rpx;
  color: var(--ink-4);
  margin-top: 8rpx;
}
.submit-btn {
  height: 96rpx;
  background: var(--ink);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  transition: opacity 150ms;
}
.submit-btn__label {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--white);
  letter-spacing: 2rpx;
}
.submit-btn--disabled {
  background: var(--ink-4);
  pointer-events: none;
}
.submit-btn--loading {
  opacity: 0.7;
}
.submit-btn:active {
  opacity: 0.85;
}
.footer-note {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: var(--ink-4);
  margin-top: 16rpx;
}