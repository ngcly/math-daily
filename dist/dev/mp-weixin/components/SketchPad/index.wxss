.sketchpad {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: var(--yellow);
}
.toolbar {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: var(--white);
  border-bottom: 1rpx solid var(--ink-5);
  flex-shrink: 0;
}
.toolbar__btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--paper);
  transition: background 150ms;
}
.toolbar__btn--active {
  background: var(--ink);
}
.toolbar__btn--active .toolbar__icon {
  filter: var(--icon-filter);
}
.toolbar__btn--disabled {
  opacity: 0.3;
  pointer-events: none;
}
.toolbar__btn--danger:active {
  background: var(--red-light);
}
.toolbar__btn:active {
  opacity: 0.7;
}
.toolbar__icon {
  font-size: 32rpx;
  line-height: 1;
}
.toolbar__sep {
  width: 1rpx;
  height: 36rpx;
  background: var(--ink-5);
  margin: 0 4rpx;
  flex-shrink: 0;
}
.toolbar__width {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
  transition: border-color 150ms;
}
.toolbar__width--active {
  border-color: var(--ink);
}
.toolbar__dot {
  background: var(--ink);
  border-radius: 50%;
  flex-shrink: 0;
}
.toolbar__color {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid transparent;
  transition: border-color 150ms;
}
.toolbar__color--active {
  border-color: var(--ink-3);
  outline: 3rpx solid var(--white);
}
.canvas {
  flex: 1;
  width: 100%;
  touch-action: none;
}