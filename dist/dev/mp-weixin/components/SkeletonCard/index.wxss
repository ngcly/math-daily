.skeleton {
  width: 100%;
}
@keyframes shimmer {
0% {
    opacity: 0.6;
}
50% {
    opacity: 0.9;
}
100% {
    opacity: 0.6;
}
}
.skeleton__week-strip {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: var(--white);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}
.skeleton__week-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.skeleton__dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: var(--ink-5);
  animation: shimmer 1.6s ease-in-out infinite;
}
.skeleton__week-label {
  width: 16rpx;
  height: 16rpx;
  border-radius: 2rpx;
  background: var(--ink-5);
  animation: shimmer 1.6s ease-in-out infinite;
}
.skeleton__eyebrow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.skeleton__card {
  background: var(--white);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}
.skeleton__card--narrow {
  padding: 24rpx 28rpx;
}
.skeleton__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.skeleton__tag {
  width: 140rpx;
  height: 32rpx;
  border-radius: 9999rpx;
  background: var(--ink-5);
  animation: shimmer 1.6s ease-in-out infinite;
}
.skeleton__dots-row {
  display: flex;
  gap: 6rpx;
}
.skeleton__dot-sm {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--ink-5);
  animation: shimmer 1.6s ease-in-out infinite;
}
.skeleton__dot-sm:nth-child(3) {
  animation-delay: 0.1s;
}
.skeleton__dot-sm:nth-child(4) {
  animation-delay: 0.2s;
}
.skeleton__dot-sm:nth-child(5) {
  animation-delay: 0.3s;
}
.skeleton__body {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 24rpx;
}
.skeleton__line {
  height: 24rpx;
  border-radius: 6rpx;
  background: var(--ink-5);
  animation: shimmer 1.6s ease-in-out infinite;
}
.skeleton__line--short {
  width: 45%;
}
.skeleton__line--medium {
  width: 65%;
}
.skeleton__line--long {
  width: 85%;
}
.skeleton__line--xs {
  width: 30%;
  height: 18rpx;
}
.skeleton__social-bar {
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--ink-5);
}
.skeleton__draft-area {
  min-height: 200rpx;
  border-radius: 16rpx;
  border: 3rpx dashed var(--ink-5);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}