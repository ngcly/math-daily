.answer-input__notice {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--ink-4);
  margin-top: 16rpx;
}
.answer-input__field {
  flex: 1;
  height: 88rpx;
  background: var(--paper);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink);
  border: 2rpx solid var(--ink-5);
  transition: border-color 150ms;
}
.answer-input__field:focus {
  border-color: var(--ink-3);
}
.choice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.choice-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: var(--paper);
  border-radius: 16rpx;
  border: 2rpx solid var(--ink-5);
  transition: all 150ms;
}
.choice-item--selected {
  background: var(--green-light);
  border-color: var(--green-border);
}
.choice-item--disabled {
  opacity: 0.7;
}
.choice-item:active {
  opacity: 0.8;
}
.choice-item__key {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--white);
  border: 2rpx solid var(--ink-5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
  color: var(--ink-3);
  flex-shrink: 0;
  transition: all 150ms;
}
.choice-item__key--selected {
  background: var(--green);
  border-color: var(--green);
  color: var(--white);
}
.choice-item__text {
  font-size: 28rpx;
  color: var(--ink);
  line-height: 1.5;
  flex: 1;
}
.fill-wrap {
  margin-bottom: 24rpx;
}
.fill-wrap__label {
  display: block;
  font-size: 26rpx;
  color: var(--ink-3);
  margin-bottom: 16rpx;
}
.fill-wrap__row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.fill-wrap__unit {
  font-size: 28rpx;
  color: var(--ink-2);
  font-weight: 600;
  flex-shrink: 0;
}
.fill-wrap__hint {
  display: block;
  font-size: 22rpx;
  color: var(--ink-4);
  margin-top: 10rpx;
}
.submit-btn {
  height: 96rpx;
  background: var(--ink);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  transition: opacity 150ms;
}
.submit-btn__label {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--white);
  letter-spacing: 2rpx;
}
.submit-btn--disabled {
  background: var(--ink-4);
  pointer-events: none;
}
.submit-btn--loading {
  opacity: 0.7;
}
.submit-btn:active {
  opacity: 0.85;
}