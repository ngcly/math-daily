{
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "脑生锈",
        "navigationBarBackgroundColor": "#1a1a1a",
        "navigationBarTextStyle": "white",
        "backgroundColor": "@bgPaper",
        "backgroundColorTop": "@bgPaper",
        "backgroundColorBottom": "@bgPaper"
      }
    },
    {
      "path": "pages/draft/index",
      "style": {
        "navigationBarTitleText": "草稿纸",
        "navigationBarBackgroundColor": "#1a1a1a",
        "navigationBarTextStyle": "white",
        "backgroundColor": "@bgYellow",
        "backgroundColorTop": "@bgYellow",
        "backgroundColorBottom": "@bgYellow",
        "disableScroll": true
      }
    },
    {
      "path": "pages/result/index",
      "style": {
        "navigationBarTitleText": "解析",
        "navigationBarBackgroundColor": "#1a1a1a",
        "navigationBarTextStyle": "white",
        "backgroundColor": "@bgWhite",
        "backgroundColorTop": "@bgWhite",
        "backgroundColorBottom": "@bgWhite"
      }
    },
    {
      "path": "pages/review/index",
      "style": {
        "navigationBarTitleText": "回顾",
        "navigationBarBackgroundColor": "#1a1a1a",
        "navigationBarTextStyle": "white",
        "backgroundColor": "@bgWhite",
        "backgroundColorTop": "@bgWhite",
        "backgroundColorBottom": "@bgWhite"
      }
    },
    {
      "path": "pages/history/index",
      "style": {
        "navigationBarTitleText": "我的记录",
        "navigationBarBackgroundColor": "#1a1a1a",
        "navigationBarTextStyle": "white",
        "backgroundColor": "@bgPaper",
        "backgroundColorTop": "@bgPaper",
        "backgroundColorBottom": "@bgPaper"
      }
    },
    {
      "path": "pages/settings/index",
      "style": {
        "navigationBarTitleText": "设置",
        "navigationBarBackgroundColor": "#1a1a1a",
        "navigationBarTextStyle": "white",
        "backgroundColor": "@bgPaper",
        "backgroundColorTop": "@bgPaper",
        "backgroundColorBottom": "@bgPaper"
      }
    },
    {
      "path": "pages/feedback/index",
      "style": {
        "navigationBarTitleText": "意见反馈",
        "navigationBarBackgroundColor": "#1a1a1a",
        "navigationBarTextStyle": "white",
        "backgroundColor": "@bgPaper",
        "backgroundColorTop": "@bgPaper",
        "backgroundColorBottom": "@bgPaper"
      }
    }
  ],
  "tabBar": {
    "color": "@tabFg",
    "selectedColor": "@tabActive",
    "backgroundColor": "@tabBg",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "今日题",
        "iconPath": "static/icons/home.png",
        "selectedIconPath": "@iconHomeActive"
      },
      {
        "pagePath": "pages/history/index",
        "text": "历史",
        "iconPath": "static/icons/history.png",
        "selectedIconPath": "@iconHistoryActive"
      },
      {
        "pagePath": "pages/settings/index",
        "text": "设置",
        "iconPath": "static/icons/settings.png",
        "selectedIconPath": "@iconSettingsActive"
      }
    ]
  },
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "脑生锈",
    "navigationBarBackgroundColor": "#1a1a1a",
    "backgroundColor": "@bgPaper",
    "backgroundColorTop": "@bgPaper",
    "backgroundColorBottom": "@bgPaper",
    "navigationStyle": "default"
  },
  "uniIdRouter": {}
}
